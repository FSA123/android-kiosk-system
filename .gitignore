# Excludem folderul media (fisierele video/foto sunt prea mari pentru Git)
media/
!media/.gitkeep

# Excludem log-urile de text (sunt date de test locale)
*.txt
!README.md

# SQLite database files (generated at runtime via db/init_db.php)
db/kiosk.db
db/kiosk.db-shm
db/kiosk.db-wal

# Excludem fisierele de configurare ale editorului sau sistemului
.DS_Store
Thumbs.db
.vscode/
.idea/